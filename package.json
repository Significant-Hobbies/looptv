{
  "name": "looptv",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "wrangler pages dev out",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "typecheck": "tsc --noEmit",
    "build:catalog": "bash scripts/fetch-sources.sh && bash scripts/build-catalog.sh --process-only",
    "audit:catalog": "node scripts/audit-catalog-health.mjs",
    "audit:catalog:full": "node scripts/full-catalog-rebaseline.mjs",
    "seed:local": "bash scripts/seed-local.sh",
    "build:ner": "python3 scripts/extract-tags.py",
    "fetch:all": "bash scripts/fetch-all-sources.sh",
    "cf:build": "pnpm build",
    "deploy": "pnpm cf:build && wrangler pages deploy out --project-name=looptv",
    "docs:check": "node scripts/validate-docs.mjs",
    "docs:check:strict": "node scripts/validate-docs.mjs --strict",
    "docs:build": "blume build",
    "docs:dev": "blume dev",
    "knip": "knip --no-exit-code --reporter symbols",
    "knip:strict": "knip --reporter symbols"
  },
  "dependencies": {
    "@saas-maker/feedback": "^0.2.1",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "zod": "^4.4.3",
    "posthog-js": "^1.372.1",
    "web-vitals": "^4.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "4",
    "@types/node": "25.6.0",
    "@types/react": "19",
    "@types/react-dom": "19",
    "@types/youtube": "0.2.0",
    "@vitejs/plugin-react": "6.0.1",
    "tailwindcss": "4",
    "typescript": "6.0.3",
    "vitest": "4.1.5",
    "@vitest/coverage-v8": "^4.1.9",
    "wrangler": "4.85.0",
    "knip": "^6.6.3"
  },
  "packageManager": "pnpm@10.33.2"
}
